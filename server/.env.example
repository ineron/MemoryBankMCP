# Postgres connection (matches server/docker-compose.yml defaults)
DATABASE_URL=postgresql://memory:memory@localhost:5433/memory_bank

# Embedding provider: "voyage" (default) or "openai"
EMBED_PROVIDER=voyage

# Voyage AI (used when EMBED_PROVIDER=voyage)
# Model dim must match schema.sql's `vector(N)` column width — voyage-3.5 is 1024-dim.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3.5

# OpenAI (used when EMBED_PROVIDER=openai)
# text-embedding-3-small natively outputs 1536-dim, but embeddings.py asks
# for 1024 via the `dimensions` (Matryoshka truncation) param so it stays
# compatible with schema.sql's `vector(1024)` column without a schema change.
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
